{
  "compilerOptions": {
    "esModuleInterop": true
  },
  "exclude": [
    "**/.template",
    "**/tmp/*",
    "**/temp/*",
    "**/dist/*",
    "**/build/*",
    "**/public/*",
    "**/scripts/*",
    "**/coverage/*",
    "**/node_modules/*",
    "**/__fixtures__*",
    "**/__snapshots__/*",
    "**/*.css",
    "**/*.scss"
  ],
  "extends": "@fc/react-app/tsconfig.json",
  "files": [".configs/react-app/globals.d.ts", "jest.setup.ts"],
  "include": ["**/src/**/*.d.ts", "**/src/**/*.spec.ts", "**/src/**/*.spec.tsx"]
}
