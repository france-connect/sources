# Elasticsearch 
App_NAME=command_elastic
NODE_EXTRA_CA_CERTS=/etc/ssl/elasticsearch/elasticsearch.crt

Elasticsearch_TRACKS_INDEX=tracks
Elasticsearch_NODES=["https://elasticsearch:9200"]
Elasticsearch_USERNAME=docker-stack
Elasticsearch_PASSWORD=docker-stack

# ElasticControl 
ElasticControl_METRICS_INDEX=metrics
ElasticControl_HIGH_TRACKS_INDEX=tracks
ElasticControl_LOW_TRACKS_INDEX=tracks
ElasticControl_CONTROL_INDEX=control
