TZ=Europe/Paris

ZNUNY_UPDATE=no
ZNUNY_UPGRADE=no

ZNUNY_DB_HOST=postgres
ZNUNY_DB_PORT=5432
ZNUNY_DB_NAME=pg_znuny
ZNUNY_DB_USER=znuny_user
ZNUNY_DB_PASS=znuny_pass

ZNUNY_DB_SSLMODE=verify-ca
ZNUNY_DB_SSLROOTCERT=/etc/ssl/docker-stack-ca.crt
ZNUNY_DB_SSLCERT=/etc/ssl/postgres.znuny.client.crt
ZNUNY_DB_SSLKEY=/etc/ssl/postgres.znuny.client.key

ZNUNY_ADMIN_USER=admin
ZNUNY_ADMIN_PASS=admin
ZNUNY_ADMIN_EMAIL=admin@franceconnect.gouv.fr
ZNUNY_ADMIN_FIRSTNAME=Admin
ZNUNY_ADMIN_LASTNAME=User

VIRTUAL_HOST=znuny.docker.dev-franceconnect.fr
PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games:/usr/local/games:/snap/bin"
