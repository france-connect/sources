  "compilerOptions": {
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "dom"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "types": ["cypress", "cypress-axe", "cypress-maildev"]
  },
  "include": ["fcp/**/*.ts", "partners/**/*.ts"]
}
